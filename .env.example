# ─────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your values
# We load secrets from environment variables instead.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_pass_dev
POSTGRES_DB=ecommerce_events
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MinIO (local S3)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_dev
MINIO_ENDPOINT=http://localhost:9000
S3_BUCKET=ecommerce-raw-events

# Spark
SPARK_CHECKPOINT_LOCATION=s3a://spark-checkpoints/streaming
# Stripe
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-02-25.clover

# App settings
ENVIRONMENT=development
LOG_LEVEL=INFO
